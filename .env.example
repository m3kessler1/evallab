# API Keys and Configuration
# Copy this file to .env and fill in your actual keys

# LLM Provider Selection
# Options: openai, moonshot, openrouter
LLM_PROVIDER=openrouter

# OpenAI Configuration
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Moonshot Configuration
# Get key from: https://platform.moonshot.ai/
MOONSHOT_API_KEY=sk-your-moonshot-key-here
MOONSHOT_MODEL=kimi-k2-turbo-preview
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# OpenRouter Configuration
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=evallab
# Optional but recommended by OpenRouter (public app URL)
OPENROUTER_SITE_URL=https://github.com/m3kessler1/evallab

# Langfuse Configuration
# Get from: https://cloud.langfuse.com (create a project)
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: Langfuse Debug Mode
# LANGFUSE_DEBUG=false